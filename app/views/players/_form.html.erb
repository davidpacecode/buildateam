<%= form_with(model: player) do |form| %>
  <% if player.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(player.errors.count, "error") %> prohibited this player from being saved:</h2>

      <ul>
        <% player.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :overall_rank, style: "display: block" %>
    <%= form.number_field :overall_rank %>
  </div>

  <div>
    <%= form.label :first_name, style: "display: block" %>
    <%= form.text_field :first_name %>
  </div>

  <div>
    <%= form.label :last_name, style: "display: block" %>
    <%= form.text_field :last_name %>
  </div>

  <div>
    <%= form.label :position, style: "display: block" %>
    <%= form.text_field :position %>
  </div>

  <div>
    <%= form.label :height, style: "display: block" %>
    <%= form.text_field :height %>
  </div>

  <div>
    <%= form.label :team, style: "display: block" %>
    <%= form.text_field :team %>
  </div>

  <div>
    <%= form.label :overall, style: "display: block" %>
    <%= form.number_field :overall %>
  </div>

  <div>
    <%= form.label :three_pt, style: "display: block" %>
    <%= form.number_field :three_pt %>
  </div>

  <div>
    <%= form.label :dunk, style: "display: block" %>
    <%= form.number_field :dunk %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
