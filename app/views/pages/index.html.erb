<div class="wa-stack wa-space-x-2">

  <%= turbo_frame_tag "edit_team_form" do %>
    <p>
      Select players to make the best team. Click the little hooper to start a new game
    </p>

    <p>
    <a href="<%= new_team_path %>"><wa-button variant="neutral" appearance="outlined">
        <wa-icon name="person-basketball" family="duotone" variant="solid" 
        style="--primary-color: rgb(10, 67, 168); --secondary-color: rgb(10, 67, 168);">
        </wa-icon></wa-button></a>
    </p>
  <% end %>
</div>
